---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Home">
  <section style="max-width:900px;margin:3rem auto;padding:0 1.5rem;">
    <h1 style="font-size:2.5rem;margin-bottom:.5rem;">🎮 Games Library</h1>
    <p style="color:rgba(255,255,255,.7);font-size:1.1rem;margin-bottom:2.5rem;">
      Pick a game, invite friends, and play — no account needed.
    </p>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.5rem;">
      <!-- Poker card -->
      <a href={`${base}/poker`} style="text-decoration:none;">
        <div style="background:var(--green-felt);border-radius:var(--radius);padding:1.5rem;box-shadow:var(--shadow);border:2px solid transparent;transition:border-color .2s,transform .2s;"
             onmouseover="this.style.borderColor='var(--gold)';this.style.transform='translateY(-4px)'"
             onmouseout="this.style.borderColor='transparent';this.style.transform=''">
          <div style="font-size:3rem;margin-bottom:.75rem;">🃏</div>
          <h2 style="color:var(--gold);margin-bottom:.4rem;">Poker</h2>
          <p style="color:rgba(255,255,255,.75);font-size:.9rem;">Texas Hold'em — 2 to 4 human players.<br/>No account needed, no AI opponents.</p>
          <div style="margin-top:1rem;display:flex;gap:.5rem;flex-wrap:wrap;">
            <span class="badge badge-gold">2–4 Players</span>
            <span class="badge badge-green">Human Only</span>
          </div>
        </div>
      </a>

      <!-- Sevens card -->
      <a href={`${base}/sevens`} style="text-decoration:none;">
        <div style="background:var(--green-felt);border-radius:var(--radius);padding:1.5rem;box-shadow:var(--shadow);border:2px solid transparent;transition:border-color .2s,transform .2s;"
             onmouseover="this.style.borderColor='var(--gold)';this.style.transform='translateY(-4px)'"
             onmouseout="this.style.borderColor='transparent';this.style.transform=''">
          <div style="font-size:3rem;margin-bottom:.75rem;">7️⃣</div>
          <h2 style="color:var(--gold);margin-bottom:.4rem;">Sevens</h2>
          <p style="color:rgba(255,255,255,.75);font-size:.9rem;">Fan Tan — 2 to 4 human players.<br/>Be the first to play all your cards!</p>
          <div style="margin-top:1rem;display:flex;gap:.5rem;flex-wrap:wrap;">
            <span class="badge badge-gold">2–4 Players</span>
            <span class="badge badge-green">Human Only</span>
          </div>
        </div>
      </a>
    </div>
  </section>
</Layout>
