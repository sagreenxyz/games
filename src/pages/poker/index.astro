---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Poker" description="Texas Hold'em Poker — up to 4 players, AI fills empty seats">
  <div id="app" style="max-width:1100px;margin:0 auto;padding:1rem 1rem 3rem;">

    <!-- ══ LOBBY ══ -->
    <section id="lobby" style="max-width:460px;margin:3rem auto;">
      <h1 style="text-align:center;font-size:2rem;margin-bottom:.25rem;">🃏 Poker</h1>
      <p style="text-align:center;color:rgba(255,255,255,.65);margin-bottom:2rem;">Texas Hold'em · up to 4 players · AI fills empty seats</p>

      <div style="background:var(--green-felt);border-radius:var(--radius);padding:1.5rem;box-shadow:var(--shadow);">
        <div style="margin-bottom:1rem;">
          <label for="playerName">Your display name</label>
          <input id="playerName" type="text" placeholder="e.g. Alice" maxlength="20" autocomplete="off" />
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-top:1rem;">
          <button id="btnNew" class="btn btn-primary" style="justify-content:center;">
            ✨ New Room
          </button>
          <button id="btnJoin" class="btn btn-outline" style="justify-content:center;">
            🔗 Join Room
          </button>
        </div>

        <div id="joinFields" class="hidden" style="margin-top:1rem;">
          <label for="roomCode">Room code</label>
          <div style="display:flex;gap:.5rem;">
            <input id="roomCode" type="text" placeholder="6-character code" maxlength="6" style="text-transform:uppercase;" autocomplete="off" />
            <button id="btnJoinConfirm" class="btn btn-success" style="white-space:nowrap;">Join →</button>
          </div>
        </div>

        <p id="lobbyError" style="color:#f4978e;margin-top:.75rem;font-size:.875rem;min-height:1.2em;"></p>
      </div>
    </section>

    <!-- ══ WAITING ROOM ══ -->
    <section id="waitingRoom" class="hidden" style="max-width:560px;margin:2rem auto;">
      <div style="background:var(--green-felt);border-radius:var(--radius);padding:1.5rem;box-shadow:var(--shadow);">
        <h2 style="margin-bottom:.25rem;">Waiting Room</h2>
        <p style="color:rgba(255,255,255,.6);font-size:.875rem;margin-bottom:1rem;">
          Share the room code so friends can join. AI fills empty seats when the game starts.
        </p>
        <div style="display:flex;align-items:center;gap:.75rem;background:rgba(0,0,0,.2);border-radius:8px;padding:.75rem 1rem;margin-bottom:1.25rem;">
          <span style="font-size:.875rem;color:rgba(255,255,255,.6);">Room code:</span>
          <strong id="displayRoomCode" style="font-size:1.4rem;letter-spacing:.15em;color:var(--gold);font-family:monospace;"></strong>
          <button id="btnCopyCode" class="btn btn-sm btn-outline" style="margin-left:auto;">📋 Copy</button>
        </div>

        <div id="playerSlots" style="display:grid;gap:.5rem;margin-bottom:1.25rem;"></div>

        <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
          <button id="btnStart" class="btn btn-primary hidden">🃏 Start Game</button>
          <button id="btnLeaveWaiting" class="btn btn-outline btn-sm">← Leave</button>
        </div>
        <p id="waitingMsg" style="color:rgba(255,255,255,.6);font-size:.875rem;margin-top:.75rem;"></p>
      </div>
    </section>

    <!-- ══ GAME TABLE ══ -->
    <section id="gameTable" class="hidden">

      <!-- Top info bar -->
      <div style="display:flex;align-items:center;flex-wrap:wrap;gap:.75rem;margin-bottom:1rem;background:rgba(0,0,0,.25);padding:.6rem 1rem;border-radius:var(--radius);">
        <span id="roundLabel" style="font-weight:700;font-size:1.05rem;color:var(--gold);"></span>
        <span id="phaseLabel" style="background:rgba(255,255,255,.1);border-radius:5px;padding:.2rem .6rem;font-size:.85rem;"></span>
        <span style="margin-left:auto;font-size:.85rem;color:rgba(255,255,255,.6);">Room: <strong id="tableRoomCode" style="color:var(--gold);font-family:monospace;"></strong></span>
        <button id="btnLeaveGame" class="btn btn-sm btn-danger">Drop Out</button>
      </div>

      <!-- Opponents (top row) -->
      <div id="opponentsRow" style="display:grid;grid-template-columns:repeat(3,1fr);gap:.75rem;margin-bottom:1rem;"></div>

      <!-- Community cards + pot -->
      <div style="background:var(--green-felt);border-radius:var(--radius);padding:1.25rem;box-shadow:var(--shadow);margin-bottom:1rem;text-align:center;">
        <div style="font-size:.8rem;color:rgba(255,255,255,.55);margin-bottom:.5rem;">COMMUNITY CARDS</div>
        <div id="communityCards" style="display:flex;justify-content:center;gap:.5rem;min-height:96px;align-items:center;flex-wrap:wrap;">
          <span style="color:rgba(255,255,255,.3);font-style:italic;">Cards will appear here</span>
        </div>
        <div style="margin-top:.75rem;font-size:1rem;">
          Pot: <strong id="potDisplay" style="color:var(--gold);">0</strong> chips
          &nbsp;|&nbsp; Current bet: <strong id="currentBetDisplay" style="color:var(--gold);">0</strong>
        </div>
        <div id="handRankDisplay" style="margin-top:.4rem;font-size:.85rem;color:rgba(255,255,255,.55);min-height:1.2em;"></div>
      </div>

      <!-- My hand (bottom) -->
      <div style="background:rgba(0,0,0,.3);border-radius:var(--radius);padding:1.25rem;box-shadow:var(--shadow);margin-bottom:1rem;">
        <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.75rem;flex-wrap:wrap;">
          <span id="myNameLabel" style="font-weight:700;font-size:1.1rem;"></span>
          <span id="myChipsLabel" class="chips"></span>
          <span id="myStatusBadge" style="margin-left:auto;"></span>
        </div>
        <div id="myCards" style="display:flex;gap:.5rem;flex-wrap:wrap;min-height:96px;align-items:center;">
          <span style="color:rgba(255,255,255,.3);font-style:italic;">Your cards will appear here</span>
        </div>
      </div>

      <!-- Action panel -->
      <div id="actionPanel" style="background:rgba(0,0,0,.3);border-radius:var(--radius);padding:1.25rem;">
        <div id="turnIndicator" style="font-size:.9rem;color:rgba(255,255,255,.6);margin-bottom:.75rem;min-height:1.3em;"></div>
        <div id="actionButtons" style="display:flex;gap:.75rem;flex-wrap:wrap;align-items:center;">
          <button id="btnFold"  class="btn btn-danger"   disabled>Fold</button>
          <button id="btnCheck" class="btn btn-outline"  disabled>Check</button>
          <button id="btnCall"  class="btn btn-success"  disabled>Call</button>
          <div style="display:flex;gap:.5rem;align-items:center;">
            <button id="btnRaise" class="btn btn-primary" disabled>Raise</button>
            <input id="raiseAmount" type="number" min="20" step="10"
                   style="width:90px;display:inline-block;"
                   placeholder="amount" />
          </div>
        </div>
        <div id="gameMessage" style="margin-top:.75rem;font-size:.95rem;min-height:1.3em;color:var(--gold);font-weight:600;"></div>
      </div>

    </section>
  </div>
</Layout>

<!-- Gun.js for real-time sync -->
<script is:inline src="https://cdn.jsdelivr.net/npm/gun/gun.js"></script>
<!-- Poker game logic -->
<script is:inline src="/games/poker-game.js"></script>
